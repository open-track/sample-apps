# Required: your OpenTrack API key
# Get started: https://developers.opentrack.co/docs/getting-started
OPENTRACK_API_KEY=

# Optional: defaults to https://api.opentrack.co
# OPENTRACK_API_URL=https://api.opentrack.co

# Optional: run with canned demo responses (no API key required)
# Try MSCU1234567, MAEU589677982, or NOTFOUND
# DEMO_MODE=true

# Optional: shown when a search does not match a tracked shipment
# SUPPORT_CONTACT_MESSAGE=Contact your OpenTrack representative to start tracking this shipment.

# Production server port (npm run start)
PORT=4173
